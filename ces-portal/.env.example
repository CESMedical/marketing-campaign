# Database (Railway MySQL service — use ${{ MySQL.MYSQL_URL }} in Railway vars)
DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE"

# Next-Auth
AUTH_URL="https://your-domain.example"
AUTH_SECRET="replace-me"

# Microsoft Entra ID (Azure AD)
AZURE_AD_CLIENT_ID="replace-me"
AZURE_AD_CLIENT_SECRET="replace-me"
AZURE_AD_TENANT_ID="replace-me"

# Role-based access control
# Comma-separated email addresses for each role.
# Roles: admin > editor > clinical_reviewer / brand_reviewer > viewer
# Change these in Railway env vars — no code change or redeploy needed.
ADMIN_EMAILS=kush@alastralabs.com,miran@alastralabs.com
EDITOR_EMAILS=
CLINICAL_REVIEWER_EMAILS=
BRAND_REVIEWER_EMAILS=

# Allowed sign-in domains (anyone outside these is rejected at login).
# Leave empty to fall back to alastralabs.com + cesmedical.co.uk.
ALLOWED_EMAIL_DOMAINS=alastralabs.com,cesmedical.co.uk

# Cloudinary (durable image storage — get these from cloudinary.com dashboard)
# If not set, uploads fall back to local public/uploads/ (dev only).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
