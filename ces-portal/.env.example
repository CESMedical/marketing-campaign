# Database (Railway MySQL service — use ${{ MySQL.MYSQL_URL }} in Railway vars)
DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE"

# Next-Auth
AUTH_URL="https://your-domain.example"
AUTH_SECRET="replace-me"

# Microsoft Entra ID (Azure AD)
AZURE_AD_CLIENT_ID="replace-me"
AZURE_AD_CLIENT_SECRET="replace-me"
AZURE_AD_TENANT_ID="replace-me"

# Role-based access control
# Comma-separated email addresses for each role.
# Roles: admin > editor > clinical_reviewer / brand_reviewer > viewer
# Change these in Railway env vars — no code change or redeploy needed.
ADMIN_EMAILS=kush@alastralabs.com,miran@alastralabs.com
EDITOR_EMAILS=
CLINICAL_REVIEWER_EMAILS=
BRAND_REVIEWER_EMAILS=

# Allowed sign-in domains (anyone outside these is rejected at login).
# Leave empty to fall back to alastralabs.com + cesmedical.co.uk.
ALLOWED_EMAIL_DOMAINS=alastralabs.com,cesmedical.co.uk

# ── Image storage — pick ONE provider. R2 takes priority over Cloudinary. ──────

# Cloudflare R2 (recommended: zero egress fees, free tier covers this project)
# Setup (10 min):
# 1. dash.cloudflare.com → R2 → Create bucket → name: ces-portal-media
# 2. Bucket settings → Public access → Allow access → copy the r2.dev public URL
#    (or connect a custom domain like media.cesmedical.co.uk)
# 3. My Profile → API Tokens → Create Token → R2:Edit on ces-portal-media bucket
#    Copy Account ID, Access Key ID, Secret Access Key
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=ces-portal-media
R2_PUBLIC_URL=https://pub-xxxx.r2.dev   # or https://media.cesmedical.co.uk

# Cloudinary (fallback if R2 env vars are not set)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
