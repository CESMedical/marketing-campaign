generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Post {
  id                   String    @id
  slug                 String    @unique
  title                String
  pillar               String
  platforms            Json
  status               String
  scheduledDate        String
  weekNumber           Int
  isCommercialPriority Boolean   @default(false)
  service              String?
  format               String
  caption              String    @db.Text
  cta                  Json
  asset                Json?
  productionLocation   String?
  productionLead       String?
  clinicalReviewer     String?
  brandReviewer        String?
  approvedAt           String?
  imageUrl             String?
  images               Json?
  notes                String?   @db.Text
  tags                 Json?
  sortOrder            Int       @default(0)
  roadmapId            String?
  roadmap              Roadmap?  @relation(fields: [roadmapId], references: [id], onDelete: SetNull)
  comments             Comment[]
  updatedAt            DateTime  @updatedAt

  @@index([roadmapId])

  @@index([slug])
  @@index([scheduledDate])
  @@index([status])
}

model Roadmap {
  id                   String    @id @default(uuid())
  title                String
  strategyTitle        String?
  strategyFileUrl      String?
  strategyFileName     String?
  strategyUploadedBy   String?
  strategyUploadedAt   DateTime?
  canvasLayout         Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  posts                Post[]
}

model EmailLog {
  id          String   @id @default(uuid())
  type        String
  to          String
  subject     String
  postSlug    String?
  triggeredBy String?
  createdAt   DateTime @default(now())

  @@index([postSlug])
  @@index([createdAt])
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  firstName   String
  role        String   @default("viewer")
  welcomeSent Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([email])
}

model Comment {
  id          String   @id @default(uuid())
  postSlug    String
  authorName  String
  authorEmail String
  text        String   @db.Text
  createdAt   DateTime @default(now())
  post        Post     @relation(fields: [postSlug], references: [slug], onDelete: Cascade)

  @@index([postSlug])
  @@index([authorEmail])
}
